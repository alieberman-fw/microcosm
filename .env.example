# Copy to .env.local and fill in. .env.local is gitignored — never commit keys.

# ---- Anthropic (the engine's only model provider) ----
# console.anthropic.com → API keys. Set a monthly spend limit in Billing → Limits.
ANTHROPIC_API_KEY=

# ---- Supabase project (app runtime) ----
# supabase.com dashboard → your project → Settings → API
# URL + anon key are public (shipped to the browser); service_role is SERVER-ONLY.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase CLI (migrations; account-level) ----
# supabase.com/dashboard/account/tokens → Generate new token
SUPABASE_ACCESS_TOKEN=
# Settings → Database → password you chose at project creation (for `supabase db push`)
SUPABASE_DB_PASSWORD=

# ---- Optional ----
# vercel.com/account/tokens — only needed for CLI-managed env vars/deploys;
# not required now that the GitHub integration deploys automatically.
VERCEL_TOKEN=
